DATABASE_URL=
AI_GATEWAY_API_KEY=

# Better Auth
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — email/password works without these)
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend) — password resets + "finish your book" reminders
# EMAIL_FROM must be on a domain verified in Resend
RESEND_API_KEY=
EMAIL_FROM=Les Flèches <bonjour@lesfleches.com>
# Protects the cron endpoint; generate with: openssl rand -hex 24
CRON_SECRET=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-01
SANITY_API_READ_TOKEN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
